<?xml version="1.0" encoding="UTF-8"?>
<querylist>
	<query name="ПоступлениеТоваров">
		<text>ВЫБРАТЬ
	ПоступлениеТоваров.Контрагент КАК Контрагент,
	ПоступлениеТоваров.СуммаДокумента КАК СуммаПоставки
ИЗ
	Документ.ПоступлениеТоваров КАК ПоступлениеТоваров

СГРУППИРОВАТЬ ПО
	ПоступлениеТоваров.Контрагент,
	ПоступлениеТоваров.СуммаДокумента
ИТОГИ
	СУММА(СуммаДокумента)
ПО
	Контрагент
</text>
	</query>
</querylist>